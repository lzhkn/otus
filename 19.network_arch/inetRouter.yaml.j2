network:
  version: 2
  renderer: networkd
  ethernets:
    ens18:
      # mgmt — статический IP, выход в интернет через gateway провайдера
      addresses:
        - 192.168.0.130/24
      routes:
        - to: 0.0.0.0/0
          via: 192.168.0.32
      nameservers:
        addresses: [8.8.8.8, 8.8.4.4]
    ens19:
      # router-net: линк до centralRouter (192.168.255.0/30)
      addresses:
        - 192.168.255.1/30
      routes:
        # Обратный маршрут — все приватные сети через centralRouter
        - to: 192.168.0.0/16
          via: 192.168.255.2
