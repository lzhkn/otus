network:
  version: 2
  renderer: networkd
  ethernets:
    ens18:
      # mgmt — статический IP, только для SSH-доступа
      addresses:
        - 192.168.0.131/24
      nameservers:
        addresses: [8.8.8.8, 8.8.4.4]
    ens19:
      # router-net: линк до inetRouter (192.168.255.0/30)
      addresses:
        - 192.168.255.2/30
      routes:
        - to: 0.0.0.0/0
          via: 192.168.255.1
    ens20:
      # directors (192.168.0.0/28)
      addresses:
        - 192.168.0.1/28
    ens21:
      # office hardware central (192.168.0.32/28)
      addresses:
        - 192.168.0.33/28
    ens22:
      # wifi/mgt (192.168.0.64/26)
      addresses:
        - 192.168.0.65/26
    ens23:
      # office1-central: линк до office1Router (192.168.255.8/30)
      addresses:
        - 192.168.255.9/30
      routes:
        - to: 192.168.2.0/24
          via: 192.168.255.10
    ens24:
      # office2-central: линк до office2Router (192.168.255.4/30)
      # MAC зафиксирован из-за особенности PCI-слота в Proxmox
      match:
        macaddress: bc:24:11:49:0c:67
      set-name: ens24
      addresses:
        - 192.168.255.5/30
      routes:
        - to: 192.168.1.0/24
          via: 192.168.255.6
