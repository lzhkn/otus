network:
  version: 2
  renderer: networkd
  ethernets:
    ens18:
      # mgmt — статический IP, только для SSH-доступа
      addresses:
        - 192.168.0.134/24
      nameservers:
        addresses: [8.8.8.8, 8.8.4.4]
    ens19:
      # directors (192.168.0.0/28)
      addresses:
        - 192.168.0.2/28
      routes:
        - to: 0.0.0.0/0
          via: 192.168.0.1
